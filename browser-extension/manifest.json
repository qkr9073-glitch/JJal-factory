{
  "manifest_version": 3,
  "name": "짤공장 릴스 헌터 수집기",
  "version": "1.0.0",
  "description": "인스타 릴스·이미지 게시물과 유튜브 쇼츠의 URL·조회수·이미지를 수집해 짤공장으로 보냅니다.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/kangaroo-16.png",
      "32": "icons/kangaroo-32.png",
      "48": "icons/kangaroo-48.png",
      "128": "icons/kangaroo-128.png"
    }
  },
  "icons": {
    "16": "icons/kangaroo-16.png",
    "32": "icons/kangaroo-32.png",
    "48": "icons/kangaroo-48.png",
    "128": "icons/kangaroo-128.png"
  },
  "permissions": [
    "debugger",
    "scripting",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://www.instagram.com/*",
    "https://www.youtube.com/*",
    "http://localhost:8777/*",
    "http://127.0.0.1:8777/*"
  ],
  "background": {
    "service_worker": "background.js"
  }
}
